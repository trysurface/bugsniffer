{
  "name": "bugsniffer",
  "version": "1.0.0",
  "description": "AI-powered Slack bot that sniffs out bug reports and creates Notion tickets",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@notionhq/client": "^5.13.0",
    "@slack/bolt": "^4.6.0",
    "ioredis": "^5.10.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
